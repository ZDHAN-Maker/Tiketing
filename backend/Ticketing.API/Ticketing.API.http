Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJuYW1laWQiOiI2IiwidW5pcXVlX25hbWUiOiJCdWRpIFNhbnRvc28iLCJlbWFpbCI6ImJ1ZGkxMjNAZXhhbXBsZS5jb20iLCJyb2xlIjoiQ3VzdG9tZXIiLCJuYmYiOjE3ODM2OTIwOTEsImV4cCI6MTc4MzY5Mjk5MSwiaWF0IjoxNzgzNjkyMDkxLCJpc3MiOiJUaWNrZXRpbmcuQVBJIiwiYXVkIjoiVGlja2V0aW5nLkJsYXpvckNsaWVudCJ9.Js62bxe32p6lOqVYSTOz_pKYFkx83YrnmQX4iEy9fK0

{
  "orderId": 2,
  "userId": 5,
  "amount": 0,
  "reason": ""
}


### 3. GET SEMUA DATA REFUND (OK)
# Skenario: Admin Finance / Customer Service ingin melihat daftar semua pengajuan refund.
# Ekspektasi: 200 OK. Mengembalikan array berisi seluruh data pengajuan refund.
GET {{baseUrl}}/api/refunds
Accept: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJuYW1laWQiOiIxIiwidW5pcXVlX25hbWUiOiJCdWRpIFNhbnRvc28iLCJlbWFpbCI6ImJ1ZGkuc2FudG9zb0BleGFtcGxlLmNvbSIsInJvbGUiOiJGcmFuY2UiLCJuYmYiOjE3ODM2OTIwOTEsImV4cCI6MTc4MzY5Mjk5MSwiaWF0IjoxNzgzNjkyMDkxLCJpc3MiOiJUaWNrZXRpbmcuQVBJIiwiYXVkIjoiVGlja2V0aW5nLkJsYXpvckNsaWVudCJ9.7g


### 4. GET DETAIL REFUND BERDASARKAN ID (OK)
# Skenario: Admin mengeklik salah satu pengajuan untuk melihat detailnya secara spesifik.
# Ekspektasi: 200 OK. Mengembalikan detail dari Refund ID 1.
GET {{baseUrl}}/api/refunds/1
Accept: application/json
# Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJuYW1laWQiOiI2IiwidW5pcXVlX25hbWUiOiJCdWRpIFNhbnRvc28iLCJlbWFpbCI6ImJ1ZGkxMjNAZXhhbXBsZS5jb20iLCJyb2xlIjoiQ3VzdG9tZXIiLCJuYmYiOjE3ODM2OTIwOTEsImV4cCI6MTc4MzY5Mjk5MSwiaWF0IjoxNzgzNjkyMDkxLCJpc3MiOiJUaWNrZXRpbmcuQVBJIiwiYXVkIjoiVGlja2V0aW5nLkJsYXpvckNsaWVudCJ9.Js62bxe32p6lOqVYSTOz_pKYFkx83YrnmQX4iEy9fK0


### 5. GET DETAIL REFUND ID TIDAK DITEMUKAN (NOT FOUND)
# Skenario: Mencari detail refund dengan ID yang tidak ada di database.
# Ekspektasi: 404 Not Found dengan pesan "Refund request not found."
GET {{baseUrl}}/api/refunds/9999
Accept: application/json
# Authorization: Bearer {{financeToken}}


### 6. UPDATE STATUS REFUND - APPROVE (OK)
# Skenario: Finance menyetujui pengajuan refund setelah verifikasi, merubah status jadi 'approved'.
# Ekspektasi: 200 OK. Status berubah dan 'processedBy' terisi dengan ID staff Finance.
PATCH {{baseUrl}}/api/refunds/1/status
Content-Type: application/json
# Authorization: Bearer {{financeToken}}

{
  "status": "approved",
  "processedBy": 2
}


### 7. UPDATE STATUS REFUND - REJECTED (OK)
# Skenario: Finance menolak pengajuan refund karena tidak memenuhi syarat ketentuan pembatalan.
# Ekspektasi: 200 OK. Status berubah jadi 'rejected'.
PATCH {{baseUrl}}/api/refunds/2/status
Content-Type: application/json
# Authorization: Bearer {{financeToken}}

{
  "status": "rejected",
  "processedBy": 2
}


### 8. UJI UPDATE STATUS UNTUK ID YANG TIDAK ADA (NOT FOUND)
# Skenario: Finance mencoba mengupdate status pada ID refund yang salah/tidak ada.
# Ekspektasi: 404 Not Found karena ditolak oleh Service (KeyNotFoundException).
PATCH {{baseUrl}}/api/refunds/9999/status
Content-Type: application/json
# Authorization: Bearer {{financeToken}}

{
  "status": "processing",
  "processedBy": 2
}