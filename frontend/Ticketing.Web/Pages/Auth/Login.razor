@page "/login"
@using BlazorTicketingApp.Models
@using BlazorTicketingApp.Services.Contracts
@using Microsoft.AspNetCore.Components.Forms
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Selamat Datang</h1>
        <p class="auth-subtitle">Masuk untuk mengelola tiket Anda</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="loginModel.Email" class="auth-input" placeholder="contoh@email.com" />
                <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="loginModel.Password" type="password" class="auth-input"
                           placeholder="Masukkan password Anda" />
                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <button type="submit" class="auth-btn" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Memproses...</span>
                }
                else
                {
                    <span>Login</span>
                }
            </button>
        </EditForm>

        <p class="auth-link-text">
            Belum punya akun? <a href="/register" class="auth-link">Daftar di sini</a>
        </p>
    </div>
</div>

@code {
    private LoginRequestDto loginModel = new();
    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        var result = await AuthService.LoginAsync(loginModel);

        if (result.IsSuccessful)
        {
            NavigationManager.NavigateTo("/"); // Arahkan ke dashboard/home
        }
        else
        {
            errorMessage = result.ErrorMessage;
        }

        isLoading = false;
    }
}